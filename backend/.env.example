# =============================================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/medical_db

# -----------------------------------------------------------------------------
# LLM Provider (Required)
# Options: google, openai, ollama
# -----------------------------------------------------------------------------
LLM_PROVIDER=google

# -----------------------------------------------------------------------------
# Google AI Studio (Required if LLM_PROVIDER=google)
# Get your free API key at: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY="AIzaSyDUTePrLeWDIKLOX9c0-ieqpG19VQYdMrg"
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_EMBED_MODEL=text-embedding-004

# -----------------------------------------------------------------------------
# OpenAI (Required if LLM_PROVIDER=openai)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Ollama (Required if LLM_PROVIDER=ollama)
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# CORS (Optional - for production)
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------------
# CORS_ORIGINS=https://your-frontend.railway.app,https://yourdomain.com
